{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|accent|dim|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, size, accent, dim, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|shape|icon|outline|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, shape, icon, outline, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:success|warning|danger|info|primary|atRisk|neutral)$/]",
        "message": "<Badge> variant must be one of 'success' | 'warning' | 'danger' | 'info' | 'primary' | 'atRisk' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:dot|hollow|none)$/]",
        "message": "<Badge> shape must be one of 'dot' | 'hollow' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|pill|leadingIcon|trailingIcon|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, pill, leadingIcon, trailingIcon, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'default' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:hero|eyebrow|title|action|pad|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: hero, eyebrow, title, action, pad, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|dot|count|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: selected, dot, count, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|error|hint|optional|required|prefix|readOnly|multiline|rows|type|inputMode|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, value, onChange, placeholder, error, hint, optional, required, prefix, readOnly, multiline, rows, type, inputMode, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiDelta'] > JSXAttribute > JSXIdentifier[name!=/^(?:dir|value|note|key|ref|className|style|children)$/]",
        "message": "<KpiDelta> doesn't accept that prop. Declared props: dir, value, note."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiDelta'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<KpiDelta> dir must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Money'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|currency|variant|align|size|style|key|ref|className|style|children)$/]",
        "message": "<Money> doesn't accept that prop. Declared props: amount, currency, variant, align, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Money'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|void|negative|muted|strong)$/]",
        "message": "<Money> variant must be one of 'default' | 'void' | 'negative' | 'muted' | 'strong'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Money'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<Money> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:subLabel|showSub|size|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: subLabel, showSub, size, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
